# ==============================================================================
# Multi-stage Dockerfile for building Chocolatey on Ubuntu 22.04 (Jammy)
# ==============================================================================
#
# Stage 1 (build)  : Clones the Chocolatey repo, installs .NET SDK 8.0 and
#                    Mono, then compiles Chocolatey from source.
# Stage 2 (install): Creates a lightweight runtime image with Mono,
#                    PowerShell 7, and the chocolatey-au module for
#                    automated package updates.
#
# Usage:
#   docker build -f Dockerfile_ubuntu -t chocolatey .
#   docker run -it chocolatey
#
# ==============================================================================

# ============================ Stage 1: Build ==================================
FROM ubuntu:jammy AS build

ARG DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC

# Install base dependencies needed for building
RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y wget git apt-utils gnupg apt-transport-https curl

# === DotNET SDK Dependencies ===
# Install Microsoft package repository and .NET SDK 8.0
RUN wget https://packages.microsoft.com/config/ubuntu/22.04/packages-microsoft-prod.deb && \
    apt-get install ./packages-microsoft-prod.deb -y && apt-get update && apt-get install dotnet-sdk-8.0 -y && \
    rm ./packages-microsoft-prod.deb

# === Mono Dependencies ===
# Import the Mono GPG key, add the official repo, and install the full Mono
# SDK (required to build Chocolatey's .NET Framework 4.8 targets).
RUN gpg --homedir /tmp --no-default-keyring --keyring /usr/share/keyrings/mono-official-archive-keyring.gpg --keyserver hkp://keyserver.ubuntu.com:80 --recv-keys 3FA7E0328081BFF6A14DA29AA6A19B38D3D831EF; \
    echo "deb [signed-by=/usr/share/keyrings/mono-official-archive-keyring.gpg] https://download.mono-project.com/repo/ubuntu stable-focal main" | tee /etc/apt/sources.list.d/mono-official-stable.list; \
    apt-get update && apt-get install mono-devel mono-complete fsharp referenceassemblies-pcl ca-certificates-mono -y

# === Clone and Build Chocolatey ===
# NOTE: Full clone is required (no --depth 1) because the Cake build script
# uses GitVersion, which needs the complete git history to compute versions.
RUN git clone https://github.com/chocolatey/choco.git

WORKDIR /choco

RUN chmod +x *.sh

# Run the Cake build and copy the choco_wrapper script into the publish output
# so it is available for the install stage.
RUN ./build.sh --verbosity=diagnostic; \
    cp docker/choco_wrapper code_drop/temp/_PublishedApps/choco/net48/choco_wrapper;


# ============================ Stage 2: Install ===============================
FROM ubuntu:jammy AS install
ARG DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC

LABEL org.opencontainers.image.url="https://chocolatey.org/"
LABEL org.opencontainers.image.documentation="https://docs.chocolatey.org/"
LABEL org.opencontainers.image.source="https://github.com/chocolatey/choco"
LABEL org.opencontainers.image.vendor="Chocolatey Software, Inc"
LABEL org.opencontainers.image.licenses="Apache-2.0"
LABEL org.opencontainers.image.title="Chocolatey"
LABEL org.opencontainers.image.description="Chocolatey Client running on Mono"
LABEL org.opencontainers.image.authors="https://chocolatey.org/support"
LABEL org.opencontainers.image.base.name="index.docker.io/library/ubuntu:jammy"

# === Install Chocolatey Binaries ===
# Copy the compiled output from the build stage and place the choco wrapper
# on the PATH so it can be invoked as "choco" or "choco.exe".
ENV ChocolateyInstall=/opt/chocolatey
COPY --from=build /choco/code_drop/temp/_PublishedApps/choco/net48 /opt/chocolatey
RUN mkdir -p /opt/chocolatey/lib; \
  cp /opt/chocolatey/choco_wrapper /usr/local/bin/choco; \
  cp /opt/chocolatey/choco_wrapper /usr/local/bin/choco.exe;

# === Add Mono Repository ===
# gnupg and ca-certificates must be installed first so we can import the GPG
# key and fetch the Mono repo over HTTPS.
RUN apt-get update && apt-get install -y gnupg ca-certificates && \
    gpg --homedir /tmp --no-default-keyring --keyring /usr/share/keyrings/mono-official-archive-keyring.gpg --keyserver hkp://keyserver.ubuntu.com:80 --recv-keys 3FA7E0328081BFF6A14DA29AA6A19B38D3D831EF; \
    echo "deb [signed-by=/usr/share/keyrings/mono-official-archive-keyring.gpg] https://download.mono-project.com/repo/ubuntu stable-focal main" | tee /etc/apt/sources.list.d/mono-official-stable.list

# === Install All Runtime Dependencies ===
# Combined into a single RUN to minimise image layers. Includes:
#   - General tools: wget, git, curl
#   - Mono runtime + F#/VB compilers for running Chocolatey
#   - Kerberos libs (PowerShell dependencies)
#   - PowerShell 7.5.4 (installed via .deb)
RUN apt-get update && apt-get upgrade -y && \
    apt-get install -y \
      wget git apt-utils apt-transport-https curl \
      mono-runtime fsharp referenceassemblies-pcl ca-certificates-mono mono-vbnc nuget \
      krb5-locales libgssapi-krb5-2 libk5crypto3 libkeyutils1 libkrb5-3 libkrb5support0 && \
    wget https://github.com/PowerShell/PowerShell/releases/download/v7.5.4/powershell_7.5.4-1.deb_amd64.deb && \
    dpkg -i powershell_7.5.4-1.deb_amd64.deb && \
    rm powershell_7.5.4-1.deb_amd64.deb && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /root

# === Install Chocolatey AU Module ===
# chocolatey-au provides the Update-Package cmdlet used by the update scripts.
RUN pwsh -Command Install-Module chocolatey-au -F

# === Copy Package Sources ===
COPY src /src

WORKDIR /src

CMD ["pwsh"]